{
  "name": "@mdreview/plugin",
  "version": "0.0.3",
  "description": "A Docusaurus plugin for adding inline review comments to your documentation site",
  "keywords": ["docusaurus", "docusaurus-plugin", "mdreview", "review", "comments", "annotation", "documentation"],
  "author": "zzzze",
  "license": "MIT",
  "homepage": "https://github.com/nicepkg/mdreview#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/nicepkg/mdreview.git",
    "directory": "packages/plugin"
  },
  "bugs": {
    "url": "https://github.com/nicepkg/mdreview/issues"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "main": "lib/index.js",
  "types": "lib/index.d.ts",
  "exports": {
    ".": "./lib/index.js",
    "./api": "./lib/api/index.js",
    "./prompt": "./lib/service/prompt.js",
    "./service": "./lib/service/index.js",
    "./types": "./lib/types.js"
  },
  "files": ["lib"],
  "scripts": {
    "build": "tsc && node scripts/copy-assets.js",
    "prepublishOnly": "pnpm run build",
    "typecheck": "tsc --noEmit",
    "test": "vitest --run",
    "test:mutate": "stryker run"
  },
  "dependencies": {
    "dom-anchor-text-quote": "^4.0.2",
    "express": "^4.21.0",
    "jsonrepair": "^3.13.2",
    "lucide-react": "^0.468.0",
    "react-markdown": "^9.0.0",
    "remark-gfm": "^4.0.1",
    "uuid": "^11.1.0"
  },
  "devDependencies": {
    "@docusaurus/logger": "^3.9.2",
    "@docusaurus/types": "3.9.2",
    "@stryker-mutator/vitest-runner": "^8.0.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.0.0",
    "@testing-library/react": "^16.0.0",
    "@types/express": "^5.0.0",
    "@types/react": "^19.2.14",
    "@types/uuid": "^10.0.0",
    "happy-dom": "^17.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "typescript": "~5.6.2",
    "vitest": "^3.0.0"
  },
  "peerDependencies": {
    "@docusaurus/core": ">=3.0.0",
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0"
  }
}
