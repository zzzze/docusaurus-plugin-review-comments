{
  "name": "@review-comments/cli",
  "version": "0.0.3",
  "description": "CLI tool to review markdown documents with inline comments",
  "author": "zzzze",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/zzzze/docusaurus-plugin-review-comments.git",
    "directory": "packages/cli"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "bin": {
    "docusaurus-review": "lib/index.js"
  },
  "main": "lib/index.js",
  "files": ["lib", "dist"],
  "scripts": {
    "build:app": "vite build --config app/vite.config.ts",
    "build:server": "tsc && node scripts/copy-assets.js",
    "build": "pnpm build:app && pnpm build:server",
    "dev:app": "vite --config app/vite.config.ts",
    "prepublishOnly": "pnpm run build",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "express": "^4.21.0",
    "@review-comments/plugin": "workspace:*"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-markdown": "^9.0.0",
    "react-router-dom": "^7.0.0",
    "remark-gfm": "^4.0.1",
    "typescript": "~5.6.2",
    "vite": "^6.0.0"
  }
}
