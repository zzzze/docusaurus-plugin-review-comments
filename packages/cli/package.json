{
  "name": "@mdreview/cli",
  "version": "0.0.3",
  "description": "CLI tool to review markdown documents with inline comments",
  "author": "zzzze",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/nicepkg/mdreview.git",
    "directory": "packages/cli"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "bin": {
    "mdreview": "lib/index.js"
  },
  "main": "lib/index.js",
  "files": [
    "lib",
    "dist"
  ],
  "scripts": {
    "build:app": "vite build --config app/vite.config.ts",
    "build:server": "tsc && node scripts/copy-assets.js",
    "build": "pnpm build:app && pnpm build:server",
    "dev:app": "vite --config app/vite.config.ts",
    "prepublishOnly": "pnpm run build",
    "typecheck": "tsc --noEmit",
    "test": "vitest --run"
  },
  "dependencies": {
    "@mdreview/plugin": "workspace:*",
    "express": "^4.21.0",
    "open-browsers": "^1.4.2"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "highlight.js": "^11.11.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-markdown": "^9.0.0",
    "react-router-dom": "^7.0.0",
    "rehype-highlight": "^7.0.2",
    "remark-gfm": "^4.0.1",
    "typescript": "~5.6.2",
    "vite": "^6.0.0",
    "vitest": "^3.0.0"
  }
}
